# ── Segurança ──────────────────────────────────────────────
SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 dias

# ── Banco de dados ─────────────────────────────────────────
# SQLite (padrão para uso pessoal)
DATABASE_URL=sqlite:///./storycast.db

# PostgreSQL (quando quiser migrar)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/storycast

# ── APIs de IA ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini          # gpt-4o para melhor qualidade

ELEVENLABS_API_KEY=...

# ── Armazenamento ──────────────────────────────────────────
STORAGE_PATH=./storage             # Local (padrão)

# S3 (quando quiser migrar)
# S3_BUCKET=storycast-files
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1

# ── Servidor ───────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true
